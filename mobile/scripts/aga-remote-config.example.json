{
  "schemaVersion": 1,
  "revision": "tradjs-example-v1",
  "deviceLabel": "Kitchen AGA",
  "pollMs": 60000,
  "labels": {
    "brand": "AGA",
    "wakeHint": "Say AGA",
    "theme": "guardian-glass"
  },
  "images": {
    "guardianAura": "https://your-tradjs.example.com/assets/aga/aura.png",
    "skillLanguage": "https://your-tradjs.example.com/assets/aga/language.png"
  },
  "settings": {
    "realtimeVoice": "marin",
    "realtimeListenMode": "strict",
    "allowBargeIn": false,
    "mediaDuckingEnabled": true,
    "homeLatitude": -8.65,
    "homeLongitude": 115.22,
    "homeLabel": "home",
    "temperatureUnit": "celsius"
  },
  "realtime": {
    "model": "gpt-realtime-2",
    "voice": "marin",
    "listenMode": "strict",
    "allowBargeIn": false,
    "instructions": "Server-managed AGA personality overlay. Keep responses short and voice-first. Use server skills when selected."
  },
  "skills": [
    {
      "id": "server_language_game",
      "label": "Server language game",
      "description": "Editable language-learning game from TradJS.",
      "aliases": ["language game", "practice language"],
      "kind": "language",
      "targetLanguage": "English",
      "instructions": "Run a playful language practice game. Give one challenge, wait for the answer, then correct gently."
    }
  ],
  "tools": [
    {
      "name": "tradjs_note",
      "description": "Send a note to the TradJS automation server.",
      "endpoint": "https://your-tradjs.example.com/aga/tools",
      "parameters": {
        "type": "object",
        "properties": {
          "text": { "type": "string" },
          "kind": { "type": "string" }
        },
        "required": ["text"]
      }
    }
  ],
  "observability": {
    "endpoint": "https://your-tradjs.example.com/aga/observability",
    "sampleRate": 0.5
  },
  "updates": {
    "ota": "check",
    "apkVersion": "1.0.0",
    "apkUrl": "https://your-tradjs.example.com/downloads/aga.apk",
    "nativeUpdateRequired": false,
    "message": "New config available from TradJS."
  }
}
