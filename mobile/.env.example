EXPO_PUBLIC_ASSISTANT_WEB_URL=http://localhost:3000
EXPO_PUBLIC_AGA_WAKE_WORD=aga
EXPO_ANDROID_PACKAGE=com.geeksy.aga

# Tactile Neural Relic display
EXPO_PUBLIC_AGA_DISPLAY_MODE=tactile_relic

# Sherpa-first keyword architecture. No Android SpeechRecognizer hot mic.
# Android APK: react-native-sherpa-onnx native TurboModule.
# Browser preview: Sherpa WASM assets. Dev injector only when explicitly enabled.
EXPO_PUBLIC_AGA_KEYWORD_ENGINE=sherpa
EXPO_PUBLIC_AGA_BROWSER_KEYWORD_ENGINE=sherpa_wasm
EXPO_PUBLIC_AGA_POST_WAKE_COMMAND_ENGINE=sherpa
EXPO_PUBLIC_AGA_ALLOW_DEV_KEYWORD_INJECTOR=0

# Sherpa Android native assets
EXPO_PUBLIC_AGA_SHERPA_MODEL_DIR=assets/sherpa/kws
EXPO_PUBLIC_AGA_SHERPA_WAKE_MODEL_DIR=assets/sherpa/kws
EXPO_PUBLIC_AGA_SHERPA_MENU_MODEL_DIR=assets/sherpa/kws
EXPO_PUBLIC_AGA_SHERPA_EXECUTION_PROVIDER=xnnpack
EXPO_PUBLIC_AGA_SHERPA_SAMPLE_RATE=16000
EXPO_PUBLIC_AGA_SHERPA_FEATURE_DIM=80
EXPO_PUBLIC_AGA_SHERPA_THREADS=2

# Sherpa browser WASM assets
EXPO_PUBLIC_AGA_SHERPA_WASM_MODEL_URL=/sherpa/kws
EXPO_PUBLIC_AGA_SHERPA_WAKE_WASM_MODEL_URL=/sherpa/kws
EXPO_PUBLIC_AGA_SHERPA_MENU_WASM_MODEL_URL=/sherpa/kws

# Optional fixed-keyword fallback only. Keep only aga/stop/pause here.
EXPO_PUBLIC_AGA_PORCUPINE_ACCESS_KEY=YOUR_PICOVOICE_ACCESS_KEY
EXPO_PUBLIC_AGA_PORCUPINE_KEYWORD_PATHS=aga.ppn,stop.ppn,pause.ppn
EXPO_PUBLIC_AGA_PORCUPINE_KEYWORD_LABELS=aga,stop,pause
EXPO_PUBLIC_AGA_PORCUPINE_SENSITIVITIES=0.72,0.62,0.62

# Post-wake command layer. This is where menu numbers/letters/languages are recognized.
EXPO_PUBLIC_AGA_POST_WAKE_COMMAND_WINDOW_MS=8000
EXPO_PUBLIC_AGA_SHORT_UTTERANCE_CAPTURE_MS=6500

# Default turn path after wake. Unknown speech does not jump to live session.
EXPO_PUBLIC_AGA_DEFAULT_REASONING_PATH=stt_gpt5_tools_tts
EXPO_PUBLIC_AGA_LIVE_SESSION_POLICY=explicit_only
EXPO_PUBLIC_OPENAI_STT_MODEL=gpt-4o-mini-transcribe
EXPO_PUBLIC_OPENAI_REASONING_MODEL=gpt-5
EXPO_PUBLIC_OPENAI_API_KEY=YOUR_OPENAI_KEY

# Short local/tool replies. Direct APK keys are accepted for this controlled device build.
EXPO_PUBLIC_AGA_TTS_PROVIDER=elevenlabs
EXPO_PUBLIC_ELEVENLABS_API_KEY=YOUR_ELEVENLABS_KEY
EXPO_PUBLIC_ELEVENLABS_VOICE_ID=YOUR_VOICE_ID
EXPO_PUBLIC_ELEVENLABS_MODEL=eleven_flash_v2_5
EXPO_PUBLIC_ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
EXPO_PUBLIC_OPENAI_TTS_MODEL=gpt-4o-mini-tts
EXPO_PUBLIC_OPENAI_TTS_VOICE=shimmer

# Live sessions are explicit only: “practice English”, “conversation mode”, “hands free”, etc.
EXPO_PUBLIC_AGA_ENGINE=gemini
EXPO_PUBLIC_GEMINI_API_KEY=YOUR_GEMINI_KEY
EXPO_PUBLIC_AGA_GEMINI_TRANSPORT=duplex
EXPO_PUBLIC_OPENAI_REALTIME_MODEL=gpt-realtime-2
EXPO_PUBLIC_OPENAI_REALTIME_VOICE=shimmer
