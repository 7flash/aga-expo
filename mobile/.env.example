EXPO_PUBLIC_ASSISTANT_WEB_URL=http://localhost:3000
EXPO_PUBLIC_AGA_WAKE_WORD=aga
EXPO_ANDROID_PACKAGE=com.geeksy.aga

# Appliance runtime: no Android SpeechRecognizer hot mic. Porcupine listens locally for keyword indexes.
EXPO_PUBLIC_AGA_WAKE_ENGINE=porcupine
EXPO_PUBLIC_AGA_PORCUPINE_ACCESS_KEY=YOUR_PICOVOICE_ACCESS_KEY
EXPO_PUBLIC_AGA_PORCUPINE_KEYWORD_PATHS=aga.ppn,stop.ppn,pause.ppn
EXPO_PUBLIC_AGA_PORCUPINE_KEYWORD_LABELS=aga,stop,pause
EXPO_PUBLIC_AGA_PORCUPINE_SENSITIVITIES=0.72,0.62,0.62

# Short local/tool replies. Direct APK keys are accepted for this controlled device build.
EXPO_PUBLIC_AGA_TTS_PROVIDER=elevenlabs
EXPO_PUBLIC_ELEVENLABS_API_KEY=YOUR_ELEVENLABS_KEY
EXPO_PUBLIC_ELEVENLABS_VOICE_ID=YOUR_VOICE_ID
EXPO_PUBLIC_ELEVENLABS_MODEL=eleven_flash_v2_5
EXPO_PUBLIC_ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
EXPO_PUBLIC_OPENAI_API_KEY=YOUR_OPENAI_KEY
EXPO_PUBLIC_OPENAI_TTS_MODEL=gpt-4o-mini-tts
EXPO_PUBLIC_OPENAI_TTS_VOICE=shimmer

# Live session escalation. AGA uses short TTS unless a turn needs live audio/reasoning.
EXPO_PUBLIC_AGA_ENGINE=gemini
EXPO_PUBLIC_AGA_LIVE_ESCALATION=auto
EXPO_PUBLIC_AGA_SHORT_REPLY_MAX_CHARS=260
EXPO_PUBLIC_AGA_POST_WAKE_REPLY=Yes?
EXPO_PUBLIC_AGA_LIVE_AFTER_WAKE=1
EXPO_PUBLIC_GEMINI_API_KEY=YOUR_GEMINI_KEY
EXPO_PUBLIC_AGA_GEMINI_TRANSPORT=duplex
EXPO_PUBLIC_OPENAI_REALTIME_MODEL=gpt-realtime-2
EXPO_PUBLIC_OPENAI_REALTIME_VOICE=shimmer

# Tactile Relic display
EXPO_PUBLIC_AGA_DISPLAY_MODE=tactile_relic

# Browser / Galaxy web preview only. The APK still uses Porcupine.
EXPO_PUBLIC_AGA_ALLOW_WEB_SPEECH_PREVIEW=1
EXPO_PUBLIC_AGA_WEB_SPEECH_LANG=en-US
EXPO_PUBLIC_AGA_WEB_WAKE_ARM_MS=9000
EXPO_PUBLIC_AGA_WEB_SPEECH_RESTART_MS=350

# Wake architecture: Porcupine keyword spotting only for hot mic.
# Android/iOS: @picovoice/porcupine-react-native keyword paths.
# Web preview: set EXPO_PUBLIC_AGA_WEB_WAKE_ENGINE=porcupine for web .ppn/WASM assets,
# or =dev to test routing with console helpers. Do not use browser SpeechRecognition as wake.
EXPO_PUBLIC_AGA_WAKE_ENGINE=porcupine
EXPO_PUBLIC_AGA_WEB_WAKE_ENGINE=dev
EXPO_PUBLIC_PICOVOICE_ACCESS_KEY=
EXPO_PUBLIC_AGA_PORCUPINE_LABELS=aga,stop,pause
EXPO_PUBLIC_AGA_PORCUPINE_ANDROID_KEYWORDS=aga.ppn,stop.ppn,pause.ppn
EXPO_PUBLIC_AGA_PORCUPINE_WEB_KEYWORDS=/porcupine/aga_web.ppn,/porcupine/stop_web.ppn,/porcupine/pause_web.ppn

# Post-wake command layer. Porcupine is not used for menu numbers/letters.
# Use dev for browser testing, rhino/cheetah for local command recognition, or live to go straight to Gemini/OpenAI.
EXPO_PUBLIC_AGA_POST_WAKE_COMMAND_ENGINE=auto
EXPO_PUBLIC_AGA_POST_WAKE_COMMAND_WINDOW_MS=8000
EXPO_PUBLIC_AGA_RHINO_CONTEXTS=
EXPO_PUBLIC_AGA_CHEETAH_LANGUAGE=en
