EXPO_PUBLIC_ASSISTANT_WEB_URL=http://localhost:3000
EXPO_ANDROID_PACKAGE=com.geeksy.aga

# Display
EXPO_PUBLIC_AGA_DISPLAY_MODE=true_hologram

# Brain routing
EXPO_PUBLIC_AGA_ENGINE=elevenlabs_agent
EXPO_PUBLIC_AGA_DEFAULT_REASONING_PATH=stt_gpt5_tts
EXPO_PUBLIC_AGA_LIVE_SESSION_POLICY=casual_by_default
EXPO_PUBLIC_AGA_DISABLE_OPENAI=0

# ElevenLabs Agent live transport (preferred casual/live alternative to Gemini)
# Public agent: set EXPO_PUBLIC_ELEVENLABS_AGENT_ID.
# Private agent: set EXPO_PUBLIC_ELEVENLABS_AGENT_SIGNED_URL_ENDPOINT to your server endpoint.
# Never ship xi-api-key in the client for agent signed URLs.
EXPO_PUBLIC_ELEVENLABS_AGENT_ID=
EXPO_PUBLIC_ELEVENLABS_AGENT_SIGNED_URL_ENDPOINT=
EXPO_PUBLIC_ELEVENLABS_AGENT_ENVIRONMENT=production
EXPO_PUBLIC_ELEVENLABS_AGENT_BRANCH_ID=
EXPO_PUBLIC_ELEVENLABS_AGENT_LANGUAGE=
EXPO_PUBLIC_ELEVENLABS_AGENT_PROMPT_OVERRIDE=0
EXPO_PUBLIC_ELEVENLABS_AGENT_WEBSOCKET_AUDIO=1

# Sherpa keyword engine
EXPO_PUBLIC_AGA_KEYWORD_ENGINE=sherpa
EXPO_PUBLIC_AGA_FALLBACK_KEYWORD_ENGINE=porcupine
EXPO_PUBLIC_AGA_SHERPA_MODEL_DIR=assets/kws-model
EXPO_PUBLIC_AGA_SHERPA_WASM_MODEL_URL=/sherpa/kws-model
EXPO_PUBLIC_AGA_SHERPA_EXECUTION_PROVIDER=xnnpack
EXPO_PUBLIC_AGA_SHERPA_SAMPLE_RATE=16000
EXPO_PUBLIC_AGA_SHERPA_FEATURE_DIM=80
EXPO_PUBLIC_AGA_SHERPA_THREADS=2
EXPO_PUBLIC_AGA_ALLOW_DEV_KEYWORD_INJECTOR=0

# Wake/control words
EXPO_PUBLIC_AGA_WAKE_WORD=aga
EXPO_PUBLIC_AGA_SHERPA_WAKE_KEYWORDS=aga,stop,pause
EXPO_PUBLIC_AGA_POST_WAKE_COMMAND_WINDOW_MS=8000

# Short response voice
EXPO_PUBLIC_AGA_SHORT_TTS_PROVIDER=elevenlabs
EXPO_PUBLIC_ELEVENLABS_API_KEY=
EXPO_PUBLIC_ELEVENLABS_VOICE_ID=
EXPO_PUBLIC_OPENAI_API_KEY=
EXPO_PUBLIC_GEMINI_API_KEY=

# Appliance audio/AEC/background
EXPO_PUBLIC_AGA_WAKE_FOREGROUND_SERVICE=1
EXPO_PUBLIC_AGA_LIVE_SPEAKERPHONE=1
EXPO_PUBLIC_AGA_TIER3_AEC_REQUIRED=1
EXPO_PUBLIC_AGA_AUDIO_SOURCE_ANDROID=VOICE_COMMUNICATION
EXPO_PUBLIC_AGA_IOS_AUDIO_MODE=voiceChat
EXPO_PUBLIC_AGA_SHERPA_ANDROID_EXECUTION_PROVIDER=xnnpack
EXPO_PUBLIC_AGA_SHERPA_IOS_EXECUTION_PROVIDER=coreml
EXPO_PUBLIC_AGA_SHERPA_WASM_EXECUTION_PROVIDER=wasm

EXPO_PUBLIC_AGA_REQUIRE_NATIVE_AEC=1
EXPO_PUBLIC_AGA_WAKE_FOREGROUND_REFRESH_MS=60000
EXPO_PUBLIC_AGA_SHERPA_ANDROID_PROVIDER=xnnpack
EXPO_PUBLIC_AGA_SHERPA_IOS_PROVIDER=coreml