EXPO_PUBLIC_ASSISTANT_WEB_URL=http://localhost:3000
EXPO_ANDROID_PACKAGE=com.geeksy.aga

# Display
EXPO_PUBLIC_AGA_DISPLAY_MODE=tactile_relic

# Brain routing
EXPO_PUBLIC_AGA_ENGINE=gemini
EXPO_PUBLIC_AGA_DEFAULT_REASONING_PATH=stt_gpt5_tts
EXPO_PUBLIC_AGA_LIVE_SESSION_POLICY=explicit_only
EXPO_PUBLIC_AGA_DISABLE_OPENAI=0

# Sherpa keyword engine
EXPO_PUBLIC_AGA_KEYWORD_ENGINE=sherpa
EXPO_PUBLIC_AGA_FALLBACK_KEYWORD_ENGINE=porcupine
EXPO_PUBLIC_AGA_SHERPA_MODEL_DIR=assets/kws-model
EXPO_PUBLIC_AGA_SHERPA_WASM_MODEL_URL=/sherpa/kws-model
EXPO_PUBLIC_AGA_SHERPA_EXECUTION_PROVIDER=xnnpack
EXPO_PUBLIC_AGA_SHERPA_SAMPLE_RATE=16000
EXPO_PUBLIC_AGA_SHERPA_FEATURE_DIM=80
EXPO_PUBLIC_AGA_SHERPA_THREADS=2
EXPO_PUBLIC_AGA_ALLOW_DEV_KEYWORD_INJECTOR=0

# Wake/control words
EXPO_PUBLIC_AGA_WAKE_WORD=aga
EXPO_PUBLIC_AGA_SHERPA_WAKE_KEYWORDS=aga,stop,pause
EXPO_PUBLIC_AGA_POST_WAKE_COMMAND_WINDOW_MS=8000

# Short response voice
EXPO_PUBLIC_AGA_SHORT_TTS_PROVIDER=elevenlabs
EXPO_PUBLIC_ELEVENLABS_API_KEY=
EXPO_PUBLIC_ELEVENLABS_VOICE_ID=
EXPO_PUBLIC_OPENAI_API_KEY=
EXPO_PUBLIC_GEMINI_API_KEY=
