EXPO_PUBLIC_ASSISTANT_WEB_URL=http://localhost:3000
EXPO_PUBLIC_AGA_WAKE_WORD=aga
EXPO_ANDROID_PACKAGE=com.geeksy.aga

# Behind-glass, voice-only device defaults.
EXPO_PUBLIC_AGA_DISPLAY_MODE=tactile_hologram
EXPO_PUBLIC_AGA_VISUAL_ENGINE=tactile_gl
EXPO_PUBLIC_AGA_PURE_DISPLAY=1
EXPO_PUBLIC_AGA_FORCE_SVG_AVATAR=0
EXPO_PUBLIC_AGA_HOLOGRAM_MIRROR=0
EXPO_PUBLIC_AGA_LOW_POWER_VISUALS=0

# Audio ingestion. Native modules are optional; JS falls back safely when absent.
EXPO_PUBLIC_AGA_EDGE_WAKE=optional_native
EXPO_PUBLIC_AGA_PCM_STREAMING=1
EXPO_PUBLIC_AGA_DIRECT_AUDIO_AFTER_WAKE=1
EXPO_PUBLIC_AGA_DETERMINISTIC_GUIDED=1
EXPO_PUBLIC_AGA_PREFETCH_GUIDED_AUDIO=1

# Production APKs should not allow cleartext except for trusted LAN dev builds.
EXPO_PUBLIC_AGA_ALLOW_CLEARTEXT=0
