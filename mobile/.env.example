EXPO_PUBLIC_ASSISTANT_WEB_URL=http://localhost:3000
EXPO_PUBLIC_AGA_WAKE_WORD=aga
EXPO_ANDROID_PACKAGE=com.geeksy.aga
EXPO_PUBLIC_AGA_DISPLAY_MODE=tactile_relic

# Expressive local/tool replies.
# Production: use a gateway/proxy so ElevenLabs secrets are never bundled into the APK.
EXPO_PUBLIC_AGA_TTS_PROVIDER=elevenlabs
EXPO_PUBLIC_AGA_TTS_GATEWAY_URL=
EXPO_PUBLIC_ELEVENLABS_VOICE_ID=
EXPO_PUBLIC_ELEVENLABS_MODEL_ID=eleven_flash_v2_5
EXPO_PUBLIC_ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
EXPO_PUBLIC_ELEVENLABS_STABILITY=0.45
EXPO_PUBLIC_ELEVENLABS_SIMILARITY_BOOST=0.78
EXPO_PUBLIC_ELEVENLABS_STYLE=0.18
EXPO_PUBLIC_ELEVENLABS_USE_SPEAKER_BOOST=1
EXPO_PUBLIC_ELEVENLABS_OPTIMIZE_STREAMING_LATENCY=3

# Local development only. Do not ship public ElevenLabs API keys in production APKs.
EXPO_PUBLIC_AGA_ALLOW_DIRECT_ELEVENLABS=1
EXPO_PUBLIC_ELEVENLABS_API_KEY=

# Emergency fallback only. Keep enabled for dev builds without ElevenLabs.
EXPO_PUBLIC_AGA_ALLOW_EXPO_SPEECH_FALLBACK=1
EXPO_PUBLIC_AGA_SPEAK_LOCALE=en-US
EXPO_PUBLIC_AGA_GEMINI_TTS_RATE=0.88
EXPO_PUBLIC_AGA_GEMINI_TTS_PITCH=1.06

# TradJS / backend TTS gateway secrets. Server-side only; never expose as EXPO_PUBLIC_*.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
AGA_TTS_GATEWAY_REQUIRE_TOKEN=0
AGA_TTS_GATEWAY_TOKEN=
